{
  "name": "youtube-downloader",
  "version": "2.0.0",
  "description": "A browser extension for downloading video and audio from YouTube.",
  "repository": "https://github.com/avi12/youtube-downloader",
  "author": "Avi <avi6106@gmail.com>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:stable": "tsx scripts/dev-server.ts",
    "build": "wxt build",
    "pack": "wxt zip",
    "postinstall": "wxt prepare",
    "lint": "eslint --fix",
    "fallow": "pnpx fallow fix --yes",
    "compile": "tsc --noEmit",
    "compile:scripts": "tsc -p scripts",
    "stylelint": "stylelint \"src/**/*.{css,svelte}\" --fix",
    "svelte:check": "pnpx svelte-check --tsconfig tsconfig.json"
  },
  "dependencies": {
    "@ffmpeg/core": "0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@webext-core/messaging": "^2.3.0",
    "fflate": "^0.8.2",
    "googlevideo": "^4.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ffmpeg/core-st": "0.11.1",
    "@material-symbols/svg-400": "^0.44.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@stylistic/stylelint-plugin": "^5.1.0",
    "@types/bun": "^1.3.13",
    "@types/ws": "^8.18.1",
    "@wxt-dev/module-svelte": "^2.0.5",
    "eslint": "^10.2.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-import-newlines": "^2.0.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.5.0",
    "postcss-html": "^1.8.1",
    "stylelint": "^17.9.1",
    "stylelint-config-ccb": "^3.31.4",
    "svelte": "^5.55.5",
    "svelte-eslint-parser": "^1.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "web-ext-run": "^0.2.4",
    "ws": "^8.20.0",
    "wxt": "^0.20.25"
  }
}
