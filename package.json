{
  "name": "youtube-downloader",
  "version": "2.4.4",
  "description": "A browser extension for downloading video and audio from YouTube.",
  "repository": "https://github.com/avi12/youtube-downloader",
  "author": "Avi <avi6106@gmail.com>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tsx scripts/dev-server.ts",
    "dev:firefox": "tsx scripts/dev-server.ts --firefox",
    "install:hyperv-multipass": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/install-hyperv-multipass.ps1",
    "setup:linux-vm": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/setup-linux-vm.ps1",
    "dev:linux": "tsx scripts/linux-vm-dev.ts",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "pack": "wxt zip",
    "pack:firefox": "wxt zip --browser firefox",
    "build:pack": "pnpm build && pnpm run pack",
    "build:pack:firefox": "pnpm build:firefox && pnpm run pack:firefox",
    "release": "tsx scripts/release.ts",
    "postinstall": "wxt prepare",
    "lint": "oxlint --type-aware --fix && eslint --fix",
    "compile": "tsc --noEmit",
    "stylelint": "stylelint \"src/**/*.{css,svelte}\" --fix",
    "svelte-check": "pnpx svelte-check"
  },
  "dependencies": {
    "@ffmpeg/core": "0.12.10",
    "@ffmpeg/types": "^0.12.4",
    "@ffmpeg/util": "^0.12.2",
    "@webext-core/messaging": "^3.0.2",
    "fflate": "^0.8.3",
    "googlevideo": "^4.0.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@puppeteer/browsers": "^3.0.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@stylistic/stylelint-plugin": "^5.2.0",
    "@types/ws": "^8.18.1",
    "@wxt-dev/module-svelte": "^2.0.5",
    "chokidar": "^5.0.0",
    "eslint": "^10.4.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-import-newlines": "^2.0.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "oxlint": "^1.68.0",
    "oxlint-tsgolint": "^0.23.0",
    "postcss-html": "^1.8.1",
    "stylelint": "^17.12.0",
    "stylelint-config-ccb": "^3.32.0",
    "svelte": "^5.56.2",
    "svelte-eslint-parser": "^1.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "web-ext-run": "^0.2.4",
    "ws": "^8.21.0",
    "wxt": "^0.20.26"
  }
}
