{
  "name": "youtube-downloader",
  "version": "2.0.0",
  "description": "A browser extension for downloading video and audio from YouTube.",
  "repository": "https://github.com/avi12/youtube-downloader",
  "author": "Avi <avi6106@gmail.com>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:with-profile": "bunx cross-env CHROME_WITH_PROFILE=1 wxt",
    "dev:firefox": "wxt -b firefox --mv3",
    "dev:firefox-with-profile": "bunx cross-env FIREFOX_WITH_PROFILE=1 wxt -b firefox --mv3",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox --mv3",
    "pack": "wxt zip",
    "pack:firefox": "wxt zip -b firefox --mv3",
    "postinstall": "wxt prepare",
    "lint": "eslint --fix",
    "stylelint": "stylelint . --fix",
    "svelte:check": "bunx svelte-check"
  },
  "dependencies": {
    "@ffmpeg/core": "0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@webext-core/messaging": "^2.3.0",
    "fflate": "^0.8.2",
    "googlevideo": "^4.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ffmpeg/core-st": "0.11.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@stylistic/stylelint-plugin": "^5.1.0",
    "@wxt-dev/module-svelte": "^2.0.5",
    "eslint": "^10.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-import-newlines": "^2.0.0",
    "eslint-plugin-perfectionist": "^5.7.0",
    "eslint-plugin-svelte": "^3.16.0",
    "globals": "^17.4.0",
    "postcss-html": "^1.8.1",
    "stylelint": "^17.6.0",
    "stylelint-config-ccb": "^3.31.1",
    "svelte": "^5.55.0",
    "svelte-eslint-parser": "^1.6.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "ws": "^8.20.0",
    "wxt": "^0.20.20"
  }
}
