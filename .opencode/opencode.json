{
  "$schema": "https://opencode.ai/config.json",
  "model": "qwen/qwen3-coder-30b",
  "instructions": [
    "C:/Users/Avi/.claude/projects/C--repositories-avi-youtube-downloader/memory/*.md"
  ],
  "mcp": {
    "webstorm": {
      "type": "local",
      "command": ["cmd", "/c", "npx", "@jetbrains/mcp-server"]
    },
    "flexible-monitor": {
      "type": "local",
      "command": ["npx", "tsx", "scripts/monitor-mcp.ts"]
    },
    "duckduckgo": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-duckduckgo"]
    },
    "chrome-devtools-mcp": {
      "type": "local",
      "command": ["cmd", "/c", "bunx", "chrome-devtools-mcp@latest", "--browser-url=http://localhost:9229"]
    },
    "firefox-devtools-mcp": {
      "type": "local",
      "command": ["cmd", "/c", "bunx", "firefox-devtools-mcp@latest", "--connect-existing", "--marionette-port", "2828", "--enable-script", "--enable-privileged-context"]
    }
  }
}
