{
  "mcpServers": {
    "chrome-devtools-mcp": {
      "type": "stdio",
      "command": "cmd",
      "args": ["/c", "bunx", "chrome-devtools-mcp@latest", "--browser-url=http://localhost:9222"],
      "env": {}
    },
    "firefox-devtools-mcp": {
      "type": "stdio",
      "command": "cmd",
      "args": ["/c", "bunx", "firefox-devtools-mcp@latest", "--connectExisting", "--marionettePort", "2828", "--enableScript", "--enablePrivilegedContext"],
      "env": {
        "MOZ_REMOTE_ALLOW_SYSTEM_ACCESS": "1"
      }
    }
  }
}
